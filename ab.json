export default new class Nyaa {
  // Use a more reliable community proxy or official Nyaa RSS logic
  base = 'https://torrent-search-api-livid.vercel.app/api/nyaasi/'

  async single({ titles, episode }) {
    if (!titles?.length) return []
    // Try primary title first, then fallback to others if no results
    for (const title of titles) {
      const results = await this.search(title, episode)
      if (results.length > 0) return results
    }
    return []
  }

  batch = this.single
  movie = ({ titles }) => this.single({ titles })

  async search(title, episode) {
    try {
      // Clean title: removes symbols but preserves 1080p/720p tags if present
      let query = title.replace(/[^\w\s-]/g, ' ').trim()
      if (episode) query += ` ${episode.toString().padStart(2, '0')}`

      const res = await fetch(this.base + encodeURIComponent(query))
      if (!res.ok) return []
      
      const data = await res.json()
      if (!Array.isArray(data)) return []

      return data.map(item => {
        const name = item.Name || ''
        return {
          title: name,
          link: item.Magnet,
          // Modern Hayase versions require a cleaner hash extraction
          hash: item.Magnet?.match(/btih:([A-Fa-f0-9]+)/)?.[1]?.toLowerCase() || '',
          seeders: Number(item.Seeders) || 0,
          leechers: Number(item.Leechers) || 0,
          downloads: Number(item.Downloads) || 0,
          // Parsing size strings (e.g. "1.2 GiB") into bytes helps Hayase's buffer
          size: item.Size || 'Unknown', 
          date: item.DateUploaded ? new Date(item.DateUploaded).getTime() : Date.now(),
          // Metadata tags help Hayase categorize the stream
          accuracy: this._getAccuracy(name, title),
          quality: name.includes('1080') ? '1080p' : name.includes('720') ? '720p' : 'Unknown',
          type: 'alt'
        }
      })
    } catch (err) {
      console.error("Hayase Nyaa Provider Error:", err)
      return []
    }
  }

  // Internal helper to determine if the result matches the request
  _getAccuracy(name, title) {
    const lowName = name.toLowerCase()
    const lowTitle = title.toLowerCase()
    return lowName.includes(lowTitle) ? 'high' : 'medium'
  }

  async test() {
    try {
      const res = await fetch(this.base + 'one%20piece')
      return res.ok
    } catch {
      return false
    }
  }
}()
